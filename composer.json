{
    "name": "nomba/nomba-laravel",
    "description": "Laravel integration for the Nomba PHP SDK",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "nomba/nomba-php": "@dev",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Nomba\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nomba\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nomba\\Laravel\\NombaServiceProvider"
            ],
            "aliases": {
                "Nomba": "Nomba\\Laravel\\Facades\\Nomba"
            }
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../nomba-php"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
